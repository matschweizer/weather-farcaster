# ── Deployment ───────────────────────────────────────────────────────────────
# Your Vercel domain (without https://)
NEXT_PUBLIC_DOMAIN=your-app.vercel.app

# ── Farcaster Account Association ─────────────────────────────────────────────
# Generate these via: https://farcaster.xyz/~/settings/developer-tools
# → Developer Tools → Create Manifest → enter your domain
FC_HEADER=
FC_PAYLOAD=
FC_SIGNATURE=
